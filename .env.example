# Spotify Client Credentials (app-to-app; no user login).
# Create an app at https://developer.spotify.com/dashboard and copy the values.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# HTTP server port (optional; defaults to 8080).
PORT=8080

# Postgres connection string (optional). When unset the server uses an in-memory
# cache and no durable corpus. Matches docker-compose.yml:
DATABASE_URL=postgres://liner:liner@localhost:5433/liner
